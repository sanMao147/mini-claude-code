# ── OpenAI 兼容接口地址（直接填）──
BASE_URL=https://aihubmix.com/v1
# 硅基流动 : https://api.siliconflow.cn/v1
# 魔搭社区 : https://api-inference.modelscope.cn/v1

# ── API Key（服务商后台申请）──
API_KEY=sk-your-key-here

# ── 模型名（不同服务商命名不同）──
MODEL_ID=deepseek-chat
# AIHubMix  : deepseek-chat / deepseek-reasoner
# 硅基流动  : deepseek-ai/DeepSeek-V3 / deepseek-ai/DeepSeek-R1
# 魔搭社区  : deepseek-ai/DeepSeek-V3 / deepseek-ai/DeepSeek-R1

# ── 备用模型（可选，s11：连续 529 过载时自动切换）──
# FALLBACK_MODEL_ID=deepseek-reasoner
